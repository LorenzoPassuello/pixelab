<Window x:Class="Pixelab.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="550" Width="750"
        MinHeight="450" MinWidth="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" Background="#3E3E42" CornerRadius="0,3,3,0">
                                                    <Path x:Name="Arrow" Fill="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="6,4,23,4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#3E3E42" BorderBrush="#555555" BorderThickness="1" CornerRadius="3"/>
                                    <ScrollViewer Margin="4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#4E4E52"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Categories -->
        <Border Grid.Column="0" Background="#2D2D30">
            <StackPanel Margin="0,16,0,0">
                <TextBlock x:Name="SettingsHeader" Text="SETTINGS" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Margin="16,0,16,16" Opacity="0.7"/>
                <ListBox x:Name="CategoriesListBox" Background="Transparent" BorderThickness="0" SelectionChanged="CategoriesListBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border" Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#B70074"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem x:Name="CanvasMenuItem" Content="🖼  Canvas" Tag="Canvas"/>
                    <ListBoxItem x:Name="LanguageMenuItem" Content="🌐  Language" Tag="Language"/>
                    <ListBoxItem x:Name="ColorManagerMenuItem" Content="🎨  Color Manager" Tag="ColorManager"/>
                </ListBox>
            </StackPanel>
        </Border>
        
        <!-- Content -->
        <Border Grid.Column="1" Background="#1E1E1E">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock x:Name="CategoryTitle" Grid.Row="0" Text="Canvas" Foreground="#FFFFFF" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <!-- Canvas Settings Panel -->
                        <StackPanel x:Name="CanvasPanel" Visibility="Visible">
                            
                            <!-- Appearance Section -->
                            <TextBlock x:Name="AppearanceSectionHeader" Text="APPEARANCE" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="AccentColorLabel" Text="Accent Color" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border x:Name="AccentColorPreview" Width="32" Height="32" Background="#B70074" 
                                        BorderBrush="#555555" BorderThickness="1" CornerRadius="4" 
                                        Margin="0,0,12,0" Cursor="Hand" MouseLeftButtonDown="AccentColorPreview_Click"/>
                                <TextBox x:Name="AccentColorTextBox" Text="#B70074" Width="100" VerticalAlignment="Center" 
                                         Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555" Padding="8,6"
                                         TextChanged="AccentColorTextBox_TextChanged"/>
                                <Button Content="Default" Margin="8,0,0,0" Padding="8,4" Click="AccentColorDefault_Click"
                                        Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555" Cursor="Hand"/>
                            </StackPanel>
                            <TextBlock x:Name="AccentColorDesc" Text="Main interface color (buttons, highlights)" 
                                       Foreground="#888888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            
                            <Separator Background="#3F3F46" Margin="0,0,0,16"/>
                            
                            <!-- Canvas Section -->
                            <TextBlock x:Name="CanvasSectionHeader" Text="CANVAS" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="BackgroundColorLabel" Text="Background Color" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border x:Name="CanvasColorPreview" Width="32" Height="32" Background="#FFFFFF"
                                        BorderBrush="#555555" BorderThickness="1" CornerRadius="4"
                                        Margin="0,0,12,0" Cursor="Hand" MouseLeftButtonDown="CanvasColorPreview_Click"/>
                                <TextBox x:Name="CanvasColorTextBox" Text="#FFFFFF" Width="100" VerticalAlignment="Center"
                                         Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555" Padding="8,6"
                                         TextChanged="CanvasColorTextBox_TextChanged"/>
                                <Button Content="Default" Margin="8,0,0,0" Padding="8,4" Click="CanvasColorDefault_Click"
                                        Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555" Cursor="Hand"/>
                            </StackPanel>
                            
                            <Separator Background="#3F3F46" Margin="0,0,0,16"/>
                            
                            <!-- Grid Section -->
                            <TextBlock x:Name="GridSectionHeader" Text="GRID" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="GridColorLabel" Text="Grid Color" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border x:Name="GridColorPreview" Width="32" Height="32" Background="#808080" 
                                        BorderBrush="#555555" BorderThickness="1" CornerRadius="4" 
                                        Margin="0,0,12,0" Cursor="Hand" MouseLeftButtonDown="GridColorPreview_Click"/>
                                <TextBox x:Name="GridColorTextBox" Text="#808080" Width="100" VerticalAlignment="Center" 
                                         Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555" Padding="8,6"
                                         TextChanged="GridColorTextBox_TextChanged"/>
                                <Button Content="Default" Margin="8,0,0,0" Padding="8,4" Click="GridColorDefault_Click"
                                        Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555" Cursor="Hand"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="GridOpacityLabel" Text="Grid Opacity" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Slider x:Name="GridOpacitySlider" Width="200" Minimum="0" Maximum="255" Value="150" VerticalAlignment="Center" PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"/>
                                <TextBlock x:Name="GridOpacityText" Text="150" Foreground="#AAAAAA" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center" Width="30"/>
                            </StackPanel>
                            
                            <Separator Background="#3F3F46" Margin="0,0,0,16"/>
                            
                            <!-- Highlight Section -->
                            <TextBlock x:Name="HighlightSectionHeader" Text="HIGHLIGHT" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="HighlightColorLabel" Text="Highlight Color" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border x:Name="HighlightColorPreview" Width="32" Height="32" Background="#FFFF00" 
                                        BorderBrush="#555555" BorderThickness="1" CornerRadius="4" 
                                        Margin="0,0,12,0" Cursor="Hand" MouseLeftButtonDown="HighlightColorPreview_Click"/>
                                <TextBox x:Name="HighlightColorTextBox" Text="#FFFF00" Width="100" VerticalAlignment="Center" 
                                         Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555" Padding="8,6"
                                         TextChanged="HighlightColorTextBox_TextChanged"/>
                                <Button Content="Default" Margin="8,0,0,0" Padding="8,4" Click="HighlightColorDefault_Click"
                                        Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555" Cursor="Hand"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="HighlightOpacityLabel" Text="Highlight Opacity" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Slider x:Name="HighlightOpacitySlider" Width="200" Minimum="0" Maximum="255" Value="200" VerticalAlignment="Center" PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"/>
                                <TextBlock x:Name="HighlightOpacityText" Text="200" Foreground="#AAAAAA" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center" Width="30"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Language Panel -->
                        <StackPanel x:Name="LanguagePanel" Visibility="Collapsed">
                            <TextBlock x:Name="LanguageSectionHeader" Text="LANGUAGE" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="SelectLanguageLabel" Text="Select Language" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox x:Name="LanguageComboBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,16"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="LanguageComboBox_SelectionChanged">
                            </ComboBox>
                            <TextBlock x:Name="LanguageRestartNote" Text="Language change will take effect after restarting the application." 
                                       Foreground="#888888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            
                            <Separator Background="#3F3F46" Margin="0,0,0,16"/>
                            
                            <TextBlock x:Name="AvailableLanguagesHeader" Text="AVAILABLE LANGUAGES" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <StackPanel x:Name="AvailableLanguagesPanel">
                                <!-- Languages will be added dynamically -->
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Color Manager Panel -->
                        <StackPanel x:Name="ColorManagerPanel" Visibility="Collapsed">
                            <!-- Pattern Generation Settings -->
                            <TextBlock x:Name="PatternGenerationHeader" Text="PATTERN GENERATION" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            
                            <!-- Color Space -->
                            <TextBlock x:Name="ColorSpaceLabel" Text="Color Space" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox x:Name="ColorSpaceComboBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,8"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="ColorSpaceComboBox_SelectionChanged">
                                <ComboBoxItem x:Name="ColorSpaceRGB" Content="RGB" Tag="0"/>
                                <ComboBoxItem x:Name="ColorSpaceLab" Content="Lab" Tag="1"/>
                            </ComboBox>
                            <TextBlock x:Name="ColorSpaceDescription" Text="Algorithm for color matching (RGB is faster, Lab is perceptually accurate)" 
                                       Foreground="#888888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"/>
                            
                            <!-- Color Compression -->
                            <TextBlock x:Name="ColorCompressionLabel" Text="Color Compression" Foreground="#FFFFFF" FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CompressionComboBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,8"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="CompressionComboBox_SelectionChanged">
                                <ComboBoxItem x:Name="CompressionOff" Content="Off (n=1)" Tag="1"/>
                                <ComboBoxItem x:Name="CompressionLow" Content="Low (n=2)" Tag="2"/>
                                <ComboBoxItem x:Name="CompressionMedium" Content="Medium (n=3)" Tag="3"/>
                                <ComboBoxItem x:Name="CompressionHigh" Content="High (n=5)" Tag="5"/>
                            </ComboBox>
                            <TextBlock x:Name="CompressionDescription" Text="Higher compression reduces color variety by preferring already-used colors" 
                                       Foreground="#888888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            
                            <Separator Background="#3F3F46" Margin="0,0,0,16"/>
                            
                            <!-- Color Groups -->
                            <TextBlock x:Name="ColorGroupsHeader" Text="COLOR GROUPS" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="ColorGroupsDescription" Text="Enable or disable entire color groups" Foreground="#888888" FontSize="11" Margin="0,0,0,12"/>
                            <StackPanel x:Name="ColorGroupsPanel" Margin="0,0,0,20">
                                <!-- Groups will be added dynamically -->
                            </StackPanel>
                            
                            <Separator Background="#3F3F46" Margin="0,0,0,16"/>
                            
                            <!-- Custom Colors Section -->
                            <TextBlock x:Name="CustomColorsHeader" Text="CUSTOM COLORS" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="CustomColorsDescription" Text="Add your own custom colors" Foreground="#888888" FontSize="11" Margin="0,0,0,12"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="AddCustomColorButton" Content="Add Color" Click="AddCustomColor_Click"
                                        Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555"
                                        Padding="12,6" Margin="0,0,8,0" Cursor="Hand"/>
                                <Button x:Name="ImportColorsButton" Content="Add Group from JSON" Click="ImportColors_Click"
                                        Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555"
                                        Padding="12,6" Margin="0,0,8,0" Cursor="Hand"/>
                                <Button x:Name="DeleteCustomColorButton" Content="Delete Color" Click="DeleteColor_Click"
                                        Background="#3E3E42" Foreground="#FFFFFF" BorderBrush="#555555"
                                        Padding="12,6" Cursor="Hand"/>
                            </StackPanel>
                            <TextBlock x:Name="ImportColorsHint" Text="Select a JSON file with colors and assign all of them to a new group."
                                       Foreground="#666666" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,16"/>
                            
                            <Separator Background="#3F3F46" Margin="0,0,0,16"/>
                            
                            <!-- Individual Colors -->
                            <TextBlock x:Name="IndividualColorsHeader" Text="INDIVIDUAL COLORS" Foreground="#B70074" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="IndividualColorsDescription" Text="Click a color to toggle enable/disable. Right-click for favorite." Foreground="#888888" FontSize="11" Margin="0,0,0,12"/>
                            <ComboBox x:Name="ColorGroupFilterComboBox" Width="180" HorizontalAlignment="Left" Margin="0,0,0,12"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="ColorGroupFilter_SelectionChanged">
                                <ComboBoxItem x:Name="AllGroupsItem" Content="All Groups" Tag="all"/>
                            </ComboBox>
                            <Border Background="#2D2D30" CornerRadius="4" Padding="8" MaxHeight="300">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="ColorsPanel">
                                        <!-- Colors will be added dynamically with group headers -->
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            <TextBlock x:Name="ColorCountText" Text="" Foreground="#888888" FontSize="11" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                
                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click" Background="#3E3E42" Foreground="#FFFFFF" BorderThickness="0" Padding="24,10" Margin="0,0,8,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#4E4E52"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="SaveButton" Content="Save" Click="Save_Click" Background="#B70074" Foreground="#FFFFFF" BorderThickness="0" Padding="24,10" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#9E0066"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
