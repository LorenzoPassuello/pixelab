<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Accent Colors (updated at runtime by ApplyAccentColor) -->
    <SolidColorBrush x:Key="TopBarBrush" Color="#9E0066"/>
    <SolidColorBrush x:Key="LeftPanelBrush" Color="#B70074"/>
    <SolidColorBrush x:Key="RightPanelBrush" Color="#B70074"/>
    <SolidColorBrush x:Key="CenterPanelBrush" Color="#FFFFFF"/>
    
    <!-- UI Element Brushes (updated at runtime) -->
    <SolidColorBrush x:Key="ButtonBrush" Color="#B70074"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#9E0066"/>
    <SolidColorBrush x:Key="TextBoxBrush" Color="#D668AE"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#9E0066"/>
    
    <!-- Text Colors - All White -->
    <SolidColorBrush x:Key="LightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DarkTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF"/>
    
    <!-- File Explorer Colors -->
    <SolidColorBrush x:Key="FileExplorerItemHoverBrush">#33FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="FileExplorerItemSelectedBrush">#66FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="FolderIconBrush">#FFD700</SolidColorBrush>
    <SolidColorBrush x:Key="ImageIconBrush">#32CD32</SolidColorBrush>
    
</ResourceDictionary>
